# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# APP
# Utilisé par les emails transactionnels pour générer les liens d'action.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Fallback serveur possible si NEXT_PUBLIC_APP_URL n'est pas défini.
APP_URL=http://localhost:3000

# AUTH (Note: Utilise Supabase Auth par défaut)
# Pas besoin de NEXTAUTH_SECRET ou NEXTAUTH_URL

#url de the-crawl
THE_CRAWL_URL=https://the-crawl.vercel.app/

# EMAIL TRANSACTIONNEL
# Dev recommandé : mailtrap
# Prod recommandé : brevo
# Défaut si absent : mailtrap hors production, brevo en production.
EMAIL_PROVIDER=mailtrap

# Expéditeur utilisé par Mailtrap/Brevo.
# Défauts si absents : noreply@the-walk.local / The-Walk.
EMAIL_FROM_EMAIL=noreply@the-walk.local
EMAIL_FROM_NAME=The-Walk

# Quota mensuel par utilisateur émetteur.
# Défaut si absent ou invalide : 20.
EMAIL_MONTHLY_QUOTA=20

# Garde-fou de test : si renseigné, tous les emails partent vers cette adresse.
# L'adresse initialement visée est conservée en metadata du journal.
ALWAYS_MAIL_TO=

# Mailtrap (dev)
MAILTRAP_API_TOKEN=your-mailtrap-api-token
# Optionnel : défaut https://send.api.mailtrap.io/api/send
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send

# Brevo (prod)
BREVO_API_KEY=your-brevo-api-key
# Optionnel : défaut https://api.brevo.com/v3/smtp/email
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
